# Required at build/runtime for API calls (set in Vercel / Docker / .env.local).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional — default placeholder image is used if empty (see lib/env/public-env.ts).
NEXT_PUBLIC_SUITE_IMAGE_FALLBACK_URL=

# Admin: Supabase Auth (same project as backend SUPABASE_URL).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Demo mode (optional): bypass Supabase login for customer demos.
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=demo@sunshine.local
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=demo1234
NEXT_PUBLIC_DEMO_ADMIN_NAME=Demo Admin
